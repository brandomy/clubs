{
  "name": "rotary-speakers",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pwa": "VITE_PWA_DEV=true vite --force",
    "build": "tsc -b && vite build && npm run build:functions",
    "build:functions": "cd functions && npm install && tsc --project tsconfig.json && cd ..",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:pwa": "npm run build && vite preview",
    "lighthouse": "npm run build && lhci autorun"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/react-router-dom": "^5.3.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.544.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.17",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "sharp": "^0.34.4",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  }
}
