{
  "name": "pitchmasters-club-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pwa": "VITE_PWA_DEV=true vite --force",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:pwa": "npm run build && vite preview",
    "lighthouse": "npm run build && lhci autorun",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "migrate": "bash scripts/migrate.sh"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@floating-ui/dom": "^1.7.6",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@react-pdf/renderer": "^4.4.1",
    "@supabase/supabase-js": "^2.103.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.544.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  }
